# ======================================
# ESTOQUEFACIL - VARIÁVEIS DE AMBIENTE
# ======================================
# Copie este arquivo para .env e preencha com seus valores

# Banco de Dados
SPRING_DATASOURCE_PASSWORD=sua_senha_aqui
POSTGRES_PASSWORD=sua_senha_aqui

# JWT Security (gere uma chave com: openssl rand -hex 32)
JWT_SECRET=SUA_CHAVE_JWT_AQUI_MINIMO_32_CARACTERES

# Admin inicial (opcional - o DataInitializer usará esses valores)
ADMIN_EMAIL=admin@estoque.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrador

# CORS (opcional)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000